# Environment variables
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/automotive

# Registry
REGISTRY_URL=registry.example.com
REGISTRY_USER=
REGISTRY_PASSWORD=

# Kubernetes
KUBECONFIG=~/.kube/config

# Argo CD
ARGOCD_SERVER=localhost:8080
ARGOCD_AUTH_TOKEN=

# Logging
LOG_LEVEL=INFO
